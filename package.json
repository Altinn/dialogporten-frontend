{
  "name": "dialogporten-frontend",
  "version": "1.164.0",
  "private": true,
  "scripts": {
    "hooks:enable": "git config core.hooksPath .hooks",
    "hooks:disable": "git config --unset core.hooksPath",
    "hooks:status": "if [ \"$(git config core.hooksPath)\" == \".hooks\" ]; then echo 'Git hooks is enabled'; else echo 'git hooks is disabled'; fi",
    "biome:fix-staged": "pnpm husky check --staged --fix",
    "biome:fix": "pnpm biome check --no-errors-on-unmatched --write"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "lint-staged": "^16.0.0",
    "mprocs": "^0.9.0",
    "turbo": "2.9.14"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "lint-staged": {
    "**/*.*": "biome check --staged --no-errors-on-unmatched --write"
  },
  "packageManager": "pnpm@10.15.1",
  "msw": {
    "workerDirectory": [
      "dist"
    ]
  },
  "pnpm": {
    "overrides": {
      "mdast-util-gfm-autolink-literal": "2.0.0",
      "protobufjs": ">=8.4.1 <9.0.0",
      "shell-quote": ">=1.8.4",
      "qs": ">=6.15.2 <7.0.0",
      "minimatch@<3.1.4": ">=3.1.4 <4.0.0",
      "minimatch@>=9.0.0 <9.0.7": ">=9.0.7 <10.0.0",
      "serialize-javascript": ">=7.0.5 <8.0.0",
      "svgo@>=3.0.0 <3.3.3": ">=3.3.3 <4.0.0",
      "undici@>=7.0.0 <7.28.0": ">=7.28.0 <8.0.0",
      "path-to-regexp@<0.1.13": ">=0.1.13 <0.2.0",
      "brace-expansion@>=2.0.0 <2.0.3": ">=2.0.3 <3.0.0",
      "brace-expansion@>=5.0.0 <5.0.6": ">=5.0.6 <6.0.0",
      "picomatch@<2.3.2": ">=2.3.2 <3.0.0",
      "picomatch@>=4.0.0 <4.0.4": ">=4.0.4 <5.0.0",
      "yaml@>=2.0.0 <2.8.3": ">=2.8.3 <3.0.0",
      "dompurify": ">=3.4.11 <4.0.0",
      "lodash-es": ">=4.18.0 <5.0.0",
      "lodash": ">=4.18.0 <5.0.0",
      "postcss@<8.5.10": ">=8.5.10 <9.0.0",
      "immutable@<3.8.3": ">=3.8.3 <4.0.0",
      "fast-uri@<=3.1.1": ">=3.1.2 <4.0.0",
      "@protobufjs/utf8@<=1.1.0": ">=1.1.1 <2.0.0",
      "webpack-dev-server": ">=5.2.5 <6.0.0",
      "ws@>=8.0.0 <8.21.0": ">=8.21.0 <9.0.0",
      "ws@>=7.0.0 <7.5.11": ">=7.5.11 <8.0.0",
      "uuid@<11.1.1": ">=11.1.1 <12.0.0",
      "@nevware21/ts-utils@<=0.13.0": ">=0.14.0 <0.15.0",
      "mermaid@>=11.0.0-alpha.1 <=11.14.0": ">=11.15.0 <12.0.0",
      "@babel/plugin-transform-modules-systemjs@>=7.12.0 <=7.29.3": ">=7.29.4 <8.0.0",
      "@grpc/grpc-js@>=1.14.0 <1.14.4": ">=1.14.4 <2.0.0",
      "joi@<17.13.4": ">=17.13.4 <18.0.0",
      "esbuild@>=0.27.3 <0.28.1": ">=0.28.1 <0.29.0",
      "form-data@>=4.0.0 <4.0.6": ">=4.0.6 <5.0.0",
      "launch-editor@<=2.14.0": ">=2.14.1 <3.0.0",
