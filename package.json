      "@opentelemetry/core@<2.8.0": ">=2.8.0 <3.0.0",
      "http-proxy-middleware@>=0.16.0 <2.0.10": ">=2.0.10 <3.0.0",
      "js-yaml@<3.15.0": ">=3.15.0 <4.0.0",
