{
  "name": "bff-types-generated",
  "main": "src/index.ts",
  "scripts": {
    "prepare": "pnpm generate:types-gql",
    "dev": "pnpm build:watch",
    "build": "pnpm generate:types-gql",
    "build:watch": "nodemon --watch 'src/**' --watch 'queries' --ext 'ts,graphql' --exec 'pnpm build'",
    "generate:types-gql": "NODE_OPTIONS='--import @swc-node/register/esm-register' graphql-codegen-esm --config codegen.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@graphql-codegen/cli": "^5.0.6",
    "@graphql-codegen/typescript-operations": "^4.6.1",
    "@graphql-tools/stitch": "catalog:",
    "@graphql-typed-document-node/core": "^3.2.0",
    "@tsconfig/node22": "catalog:",
    "bff": "workspace:*",
    "graphql": "catalog:",
    "graphql-request": "catalog:",
    "graphql-tag": "^2.12.6",
    "nodemon": "catalog:"
  },
  "devDependencies": {
    "@graphql-codegen/typescript": "^4.1.6",
    "@graphql-codegen/typescript-graphql-request": "7.1.0",
    "@graphql-codegen/typescript-resolvers": "^4.5.1",
    "@parcel/watcher": "2.5.6",
    "@swc-node/register": "catalog:",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "type": "module"
}
