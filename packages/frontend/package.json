{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "codegen:playwright": "playwright codegen",
    "test:playwright": "playwright test --project=playwright --project=playwright-heavy",
    "test:playwright:mobile": "playwright test --project=playwright-mobile",
    "test:accessibility": "playwright test --project=accessibility",
    "install:browsers": "playwright install",
    "test:watch": "vitest watch",
    "build:docker": "docker build -f ./Dockerfile -t frontend ../..",
    "run:docker": "docker run -it -p 80:80 frontend",
    "i18n:check": "tsx ./src/i18n/check.ts",
    "i18n:sort": "tsx ./src/i18n/check.ts --sort",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@altinn/altinn-components": "0.68.17",
    "@microsoft/applicationinsights-react-js": "19.4.1",
    "@microsoft/applicationinsights-web": "3.4.3",
    "@navikt/aksel-icons": "7.40.0",
    "@tanstack/react-query": "5.90.20",
    "@tanstack/react-virtual": "3.14.2",
    "bff-types-generated": "workspace:*",
    "date-fns": "3.6.0",
    "embeddable-markdown-html": "workspace:*",
    "graphql": "catalog:",
    "graphql-request": "catalog:",
    "i18next": "26.3.6",
    "i18next-icu": "2.4.4",
    "libphonenumber-js": "1.12.42",
    "lz-string": "1.5.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "17.0.10",
    "react-router-dom": "7.18.1",
    "sse.js": "2.7.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@playwright/test": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "axe-html-reporter": "2.2.11",
    "dotenv": "catalog:",
    "jsdom": "26.1.0",
    "msw": "2.12.8",
    "tsx": "4.21.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "web-streams-polyfill": "3.3.3"
  },
  "msw": {
    "workerDirectory": [
      "public",
      "dist"
    ]
  }
}
