{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./index.ts",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview",
    "test": "vitest run",
    "bench": "vitest bench --run",
    "codegen:playwright": "playwright codegen",
    "test:playwright": "npx playwright test --project=playwright --project=playwright-heavy",
    "test:playwright:mobile": "npx playwright test --project=playwright-mobile",
    "test:accessibility": "npx playwright test --project=accessibility",
    "install:browsers": "playwright install",
    "test:watch": "vitest watch",
    "build:docker": "docker build -f ./Dockerfile -t frontend ../..",
    "run:docker": "docker run -it -p 80:80 frontend",
    "i18n:check": "tsx ./src/i18n/check.ts",
    "i18n:sort": "tsx ./src/i18n/check.ts --sort",
    "doctor": "npx react-doctor@latest"
  },
  "dependencies": {
    "@altinn/altinn-components": "0.68.17",
    "@microsoft/applicationinsights-react-js": "19.4.1",
    "@microsoft/applicationinsights-web": "3.4.3",
    "@navikt/aksel-icons": "^7.37.0",
    "@tanstack/react-query": "^5.85.9",
    "@tanstack/react-virtual": "^3.14.2",
    "bff-types-generated": "workspace:*",
    "date-fns": "^3.6.0",
    "embeddable-markdown-html": "workspace:*",
    "graphql": "catalog:",
    "graphql-request": "catalog:",
    "i18next": "^23.16.8",
    "i18next-icu": "^2.3.0",
    "libphonenumber-js": "^1.12.42",
    "lz-string": "^1.5.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "^15.5.2",
    "react-router-dom": "7.18.1",
    "sse.js": "^2.6.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "catalog:",
    "@testing-library/react": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "axe-html-reporter": "^2.2.11",
    "dotenv": "catalog:",
    "jsdom": "^26.1.0",
    "msw": "^2.11.1",
    "tsx": "^4.19.4",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "catalog:",
    "web-streams-polyfill": "^3.3.3"
  },
  "msw": {
    "workerDirectory": [
      "public",
      "dist"
    ]
  }
}
